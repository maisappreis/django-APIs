{
    "version": 2,
    "builds": [
      {
        "src": "/config/wsgi.py",
        "use": "@vercel/python",
        "config": {
          "maxLambdaSize": "50mb",
          "runtime": "python3.11.9"
        }
      }
    ],
    "routes": [
      {
        "src": "/(.*)",
        "dest": "/config/wsgi.py"
      }
    ],
    "crons": [
      {
        "path": "/api/content-agent/maintenance/firebase-cleanup/",
        "schedule": "0 3 * * *"
      }
    ]
  }
  
